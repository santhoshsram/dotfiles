font-size = 17
font-family = "SauceCodePro NF Medium"
font-family = "Apple Color Emoji"
font-family-bold = "SauceCodePro NF SemiBold"
font-family-bold = "Apple Color Emoji"
font-family-italic = "SauceCodePro NF Medium Italic"
font-family-italic = "Apple Color Emoji"
font-family-bold-italic = "SauceCodePro NF SemiBold Italic"
font-family-bold-italic = "Apple Color Emoji"
font-codepoint-map = U+1F916=Apple Color Emoji
theme = Catppuccin Macchiato
cursor-style-blink = false
cursor-style = block
shell-integration-features = no-cursor
window-width = 130
window-height = 35
cursor-color = #d8c6c2
cursor-text = #15171a
copy-on-select = clipboard
keybind = shift+enter=text:\x1b\r
